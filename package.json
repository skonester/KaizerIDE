{
  "name": "kaizer-ide",
  "version": "5.2.0",
  "description": "KaizerIDE - Modern AI-Powered Desktop IDE",
  "author": "Randheimer",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5174 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "electron:build": "npm run build && electron-builder --win --x64",
    "build:win": "npm run build && electron-builder --win --x64",
    "build:win32": "npm run build && electron-builder --win --ia32",
    "build:all": "npm run build && electron-builder --win --x64 --ia32",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "lint:fix": "eslint \"src/**/*.{js,jsx}\" --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css,json}\""
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@monaco-editor/react": "^4.6.0",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.11.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^16.1.1",
    "react-virtuoso": "^4.18.6",
    "remark-gfm": "^4.0.0",
    "ssh2": "^1.15.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "prettier": "^3.2.5",
    "vite": "^6.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "dev.kaizer.ide",
    "productName": "KaizerIDE",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/**/*",
      "!src/**/*",
      "!.github/**/*",
      "!*.md",
      "!images/Preview*.png"
    ],
    "asarUnpack": [],
    "compression": "maximum",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "fileAssociations": [
        {
          "ext": [
            "js",
            "jsx",
            "ts",
            "tsx",
            "json",
            "html",
            "css",
            "md",
            "txt",
            "py",
            "java",
            "cpp",
            "c",
            "h"
          ],
          "name": "Source Code",
          "role": "Editor"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "KaizerIDE",
      "perMachine": true,
      "allowElevation": true,
      "installerIcon": "docs/images/logo.ico",
      "uninstallerIcon": "docs/images/logo.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "menuCategory": true,
      "include": "installer.nsh",
      "warningsAsErrors": false,
      "displayLanguageSelector": false,
      "installerLanguages": [
        "en_US"
      ],
      "language": "1033"
    },
    "fileAssociations": [
      {
        "ext": [
          "js",
          "jsx",
          "ts",
          "tsx",
          "json",
          "html",
          "css",
          "md",
          "txt",
          "py",
          "java",
          "cpp",
          "c",
          "h"
        ],
        "name": "Source Code",
        "description": "Open with KaizerIDE",
        "role": "Editor"
      }
    ]
  }
}
